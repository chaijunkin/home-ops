{
  "search.exclude": {
    "**/.archive": true
  },
  "editor.bracketPairColorization.enabled": true,
  "editor.fontFamily": "FiraCode Nerd Font",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.guides.bracketPairs": true,
  "editor.guides.bracketPairsHorizontal": true,
  "editor.guides.highlightActiveBracketPair": true,
  "editor.hover.delay": 1500,
  "editor.rulers": [100],
  "explorer.autoReveal": true,
  "files.associations": {
    "**/*.json5": "json5",
    "**/*.yaml.j2": "yaml"
  },
  "files.trimTrailingWhitespace": true,
  "vsicons.associations.files": [
    { "icon": "template", "extensions": ["gotmpl"], "filename": false, "format": "svg" },
    { "icon": "helm", "extensions": ["helmfile.yaml"], "filename": true, "format": "svg" },
    { "icon": "kubernetes", "extensions": ["kubeconfig", "talosconfig"], "filename": true, "format": "svg" }
  ],

  "vsicons.associations.folders": [
    // GitHub / CI
    { "icon": "github", "extensions": ["workflows", "actions-runner-system"], "format": "svg" },

    // Security & Secrets
    { "icon": "secure", "extensions": [".private", "cert-manager", "external-secrets"], "format": "svg" },

    // Updates & Automation
    { "icon": "update", "extensions": [".renovate", "system-upgrade"], "format": "svg" },

    // Storage & State
    { "icon": "database", "extensions": ["openebs-system", "rook-ceph", "bootstrap"], "format": "svg" },

    // Infrastructure & Tools
    { "icon": "helm", "extensions": ["helmfile.d"], "format": "svg" },
    { "icon": "git", "extensions": ["flux", "flux-system"], "format": "svg" },
    { "icon": "linux", "extensions": ["talos"], "format": "svg" },
    { "icon": "kubernetes", "extensions": ["kube-system"], "format": "svg" },
    { "icon": "aws", "extensions": ["volsync-system"], "format": "svg" },

    // Networking & Observability
    { "icon": "api", "extensions": ["network"], "format": "svg" },
    { "icon": "log", "extensions": ["observability"], "format": "svg" },

    // Base / Default
    { "icon": "server", "extensions": ["default"], "format": "svg" }
  ],
  "material-icon-theme.files.associations": {
    "*.gotmpl": "smarty",
    "helmfile.yaml": "helm",
    "kubeconfig": "kubernetes",
    "talosconfig": "kubernetes"
  },
  "material-icon-theme.folders.associations": {
    // top level
    ".github/workflows": "ci",
    ".private": "archive",
    ".renovate": "robot",
    "bootstrap": "seeders",
    "bootstrap/helmfile.d": "helm",
    "flux": "pipe",
    "talos": "linux",
    // namespaces
    "actions-runner-system": "github",
    "cert-manager": "guard",
    "default": "home",
    "external-secrets": "secure",
    "flux-system": "pipe",
    "kube-system": "kubernetes",
    "network": "connection",
    "observability": "event",
    "openebs-system": "base",
    "rook-ceph": "dump",
    "system-upgrade": "update",
    "volsync-system": "aws"
  },
  "terminal.integrated.fontSize": 14,
  "vs-kubernetes": {
    "vs-kubernetes.kubeconfig": "./kubeconfig",
    "vs-kubernetes.knownKubeconfigs": [
      "./kubeconfig"
    ]
  },
  "window.zoomLevel": 0,
  "yaml.schemaStore.enable": true,
  "yaml.schemas": {
    "kubernetes": "./kubernetes/**/*.yaml"
  }
}